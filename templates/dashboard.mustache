{{!
    @template local_admindashboard/dashboard

    Main admin dashboard page: global user tiles, per-school tile groups,
    health signal tiles, and grouped navigation links.

    Example context (json):
    {
        "introtext": "Overview of user and course activity...",
        "groupinglabel": "School",
        "timerangedays": 180,
        "timerangeoptions": [
            {"value": 30, "label": "30 days", "selected": false},
            {"value": 180, "label": "180 days", "selected": true}
        ],
        "dashboardurl": "http://example.com/local/admindashboard/index.php",
        "usermetrics": [
            {"label": "Total users", "value": 42, "helpicon": ""}
        ],
        "schools": [
            {
                "idnumber": "TBZ",
                "name": "TBZ Cohort",
                "tiles": [{"label": "Members", "value": 10, "helpicon": ""}],
                "coursemanagementurl": "http://example.com/course/management.php?categoryid=3"
            }
        ],
        "noschoolsconfigured": false,
        "settingsurl": "http://example.com/admin/settings.php?section=local_admindashboard_settings",
        "lastcomputedtext": "Stand: 11 July 2026, 20:00, updates daily.",
        "sesskey": "abcdef1234",
        "healthsignals": [
            {
                "label": "Duplicate emails",
                "value": 0,
                "valuetitle": "",
                "helpicon": "",
                "url": "http://example.com/x.php",
                "severitybgclass": "success",
                "severitytextclass": "text-white",
                "severityiconclass": "fa-check",
                "severitylabel": "OK"
            }
        ],
        "navgroups": [
            {"title": "User management", "items": [{"label": "Upload users", "url": "http://example.com/y.php"}]}
        ]
    }
}}
<div class="local-admindashboard">

    <p class="text-muted">{{introtext}}</p>

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <form method="get" action="{{dashboardurl}}" class="d-flex flex-wrap align-items-center m-0">
            <label for="local-admindashboard-timerangedays" class="me-2">
                {{#str}} timerange_label, local_admindashboard {{/str}}
            </label>
            <select name="timerangedays" id="local-admindashboard-timerangedays" class="form-select me-2" style="width: auto;">
                {{#timerangeoptions}}
                <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                {{/timerangeoptions}}
            </select>
            <button type="submit" class="btn btn-secondary">
                {{#str}} timerange_submit, local_admindashboard {{/str}}
            </button>
        </form>

        <div class="d-flex align-items-center text-muted small gap-2">
            <span>{{lastcomputedtext}}</span>
            <form method="post" action="{{dashboardurl}}" class="m-0">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="purgecache" value="1">
                <input type="hidden" name="timerangedays" value="{{timerangedays}}">
                <button type="submit" class="btn btn-link btn-sm p-0">
                    {{#str}} purgecache, local_admindashboard {{/str}}
                </button>
            </form>
        </div>
    </div>

    <h3>{{#str}} section_globalusers, local_admindashboard {{/str}}</h3>
    <div class="row mb-4">
        {{#usermetrics}}
        <div class="col-sm-4">
            <div class="card text-center mb-2">
                <div class="card-body">
                    <div class="h2 mb-0">{{value}}</div>
                    <div class="text-muted">{{label}} {{{helpicon}}}</div>
                </div>
            </div>
        </div>
        {{/usermetrics}}
    </div>

    <h3>{{#str}} section_schools, local_admindashboard, {{groupinglabel}} {{/str}}</h3>
    {{#noschoolsconfigured}}
    <p>
        {{#str}} noschoolsconfigured, local_admindashboard, {{groupinglabel}} {{/str}}
        <a href="{{settingsurl}}">{{#str}} noschoolsconfigured_linktext, local_admindashboard {{/str}}</a>
    </p>
    {{/noschoolsconfigured}}
    {{#schools}}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>{{name}} ({{idnumber}})</strong>
            <a href="{{coursemanagementurl}}">{{#str}} schoolcard_coursemanagement, local_admindashboard {{/str}}</a>
        </div>
        <div class="card-body">
            <div class="row">
                {{#tiles}}
                <div class="col-sm-2 text-center mb-2">
                    <div class="h4 mb-0">{{value}}</div>
                    <div class="text-muted small">{{label}} {{{helpicon}}}</div>
                </div>
                {{/tiles}}
            </div>
        </div>
    </div>
    {{/schools}}

    <h3>{{#str}} section_healthsignals, local_admindashboard {{/str}}</h3>
    <div class="row mb-4 align-items-stretch">
        {{#healthsignals}}
        <div class="col-sm-3 mb-2">
            <div class="card text-center h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="h4 mb-0" title="{{valuetitle}}">{{value}}</div>
                        <div class="text-muted">{{label}} {{{helpicon}}}</div>
                    </div>
                    <div>
                        <a href="{{url}}" class="badge bg-{{severitybgclass}} {{severitytextclass}} text-decoration-none mt-2 d-inline-flex align-items-center justify-content-center gap-1">
                            <i class="icon fa {{severityiconclass}} fa-fw" aria-hidden="true"></i>
                            {{severitylabel}}
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {{/healthsignals}}
    </div>

    <h3>{{#str}} section_navigation, local_admindashboard {{/str}}</h3>
    <div class="row">
        {{#navgroups}}
        <div class="col-sm-4 mb-4">
            <div class="card">
                <div class="card-header"><strong>{{title}}</strong></div>
                <ul class="list-group list-group-flush">
                    {{#items}}
                    <li class="list-group-item"><a href="{{url}}">{{label}}</a></li>
                    {{/items}}
                </ul>
            </div>
        </div>
        {{/navgroups}}
    </div>

</div>
